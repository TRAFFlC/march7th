# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=march7th_chat

# JWT 配置
# 必须设置至少32字符的强随机密钥，否则启动时将自动生成（重启后失效）
# 可用命令生成: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_EXPIRE_HOURS=24

# 管理员默认账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# 外部 API Key（可选）
OPENROUTER_API_KEY=

# LLM 模型配置
LLM_MODEL=deepseek-r1:8b
LLM_MAX_TOKENS=1024

# TTS 配置
TTS_PORT=9880
TTS_VERSION=v2ProPlus
REF_AUDIO_TEXT=

# 路径配置
# GPT_SOVITS_DIR: GPT-SoVITS 安装目录（TTS_GPT_WEIGHT 等留空时将基于此目录拼接）
GPT_SOVITS_DIR=
# 以下路径留空时将基于 GPT_SOVITS_DIR 自动拼接默认值
TTS_GPT_WEIGHT=
TTS_SOVITS_WEIGHT=
REF_AUDIO_PATH=
IMAGES_DIR=
OLLAMA_PATH=

# RAG 配置
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RERANK_MODEL=BAAI/bge-reranker-base

# CORS 配置（逗号分隔的允许域名列表）
# 开发环境默认: http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=

# 运行环境（development/production）
MARCH7TH_ENV=development

# 日志格式（text/json），json格式便于日志聚合分析
LOG_FORMAT=text
