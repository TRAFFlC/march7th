# ============================================
# 七音盒 Music7ox 环境变量配置
# ============================================
# 复制此文件为 .env 并填写配置
# cp .env.example .env
# ============================================

# ----------------
# 数据库配置
# ----------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=march7th_chat

# ----------------
# JWT 配置
# ----------------
# JWT_SECRET: 用于签名 Token 的密钥，请填写一个随机字符串
JWT_SECRET=your_random_secret_string_here

# ----------------
# LLM 配置
# ----------------
# Ollama 模型名称，确保已通过 ollama pull 下载
# 推荐: deepseek-r1:8b, qwen3.5:9b, llama3.1:8b
LLM_MODEL=deepseek-r1:8b
# 最大输出 Token 数
LLM_MAX_TOKENS=1024

# ----------------
# TTS 配置 (GPT-SoVITS)
# ----------------
# GPT-SoVITS API 服务端口（默认 9880）
TTS_PORT=9880
# TTS 版本（v2ProPlus 为最新版本）
TTS_VERSION=v2ProPlus

# GPT-SoVITS 安装目录（与本项目平级即可）
# 示例: 如果本项目在 D:\projects\march7th
# 则 GPT-SoVITS 放在 D:\projects\GPT-SoVITS
GPT_SOVITS_DIR=

# 模型权重路径（留空则使用 characters.json 中的配置）
TTS_GPT_WEIGHT=
TTS_SOVITS_WEIGHT=
REF_AUDIO_PATH=
REF_AUDIO_TEXT=

# ----------------
# RAG 配置
# ----------------
# 文本嵌入模型
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# 重排序模型
RERANK_MODEL=BAAI/bge-reranker-base

# ----------------
# 其他配置
# ----------------
# 图片资源目录（可选）
IMAGES_DIR=
# Ollama 可执行文件路径（可选，留空自动检测）
OLLAMA_PATH=
